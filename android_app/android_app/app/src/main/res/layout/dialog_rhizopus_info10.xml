<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/rounded_dialog_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/rounded_dialog_background">

        <TextView
            android:id="@+id/infoTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_title"
            android:textSize="16sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/diseaseDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_description"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/symptoms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_symptoms"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/prevention"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_prevention"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/treatment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_treatment"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/fertilizationCare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_fertilization_care"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/keyTakeaways"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_recommender_key_takeaways"
            android:textSize="14sp"
            android:textColor="#000000"
            android:lineSpacingExtra="8dp"
            android:maxLines="15"
            android:scrollbars="vertical"
            android:ellipsize="end" />

        <Button
            android:id="@+id/closeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Close" />

    </LinearLayout>

</ScrollView>
